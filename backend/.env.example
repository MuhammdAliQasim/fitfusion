PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRY=7d

# Optional seeded demo account email (password is demo1234 unless you set DEMO_PASSWORD_HASH)
DEMO_EMAIL=demo@fitfusion.app
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your_password', 12))"
# DEMO_PASSWORD_HASH=

# Fitbit OAuth (optional; without these values, app uses local demo connect mode)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=http://localhost:4000/api/integrations/fitbit/oauth/callback
